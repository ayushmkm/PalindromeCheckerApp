interface PalindromeStrategy {
    boolean isValid(String text);
}
class StackStrategy implements PalindromeStrategy {
    public boolean isValid(String text) {
        java.util.Stack<Character> stack = new java.util.Stack<>();
        for (char c : text.toCharArray()) stack.push(c);
        
        for (char c : text.toCharArray()) {
            if (c != stack.pop()) return false;
        }
        return true;
    }
}
class DequeStrategy implements PalindromeStrategy {
    public boolean isValid(String text) {
        java.util.Deque<Character> deque = new java.util.ArrayDeque<>();
        for (char c : text.toCharArray()) deque.addLast(c);
        
        while (deque.size() > 1) {
            if (deque.removeFirst() != deque.removeLast()) return false;
        }
        return true;
    }
}
class PalindromeContext {
    private PalindromeStrategy strategy;

    public void setStrategy(PalindromeStrategy strategy) {
        this.strategy = strategy;
    }
    public boolean executeCheck(String text) {
        String clean = text.replaceAll("[^a-zA-Z0-9]", "").toLowerCase();
        return strategy.isValid(clean);
    }
}
public class StrategyDemo {
    public static void main(String[] args) {
        PalindromeContext context = new PalindromeContext();
        String input = "Racecar";

        context.setStrategy(new StackStrategy());
        System.out.println("Using Stack: " + context.executeCheck(input));

        context.setStrategy(new DequeStrategy());
        System.out.println("Using Deque: " + context.executeCheck(input));
    }
}
